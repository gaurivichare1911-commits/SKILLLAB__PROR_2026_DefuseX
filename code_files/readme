#include <Wire.h>
#include <LiquidCrystal_I2C.h>

// ---------------- LCD ----------------
LiquidCrystal_I2C lcd(0x27, 16, 2);

// ---------------- LED ----------------
#define START_LED 10
#define TIMER_LED 11
#define RESULT_LED 14

// ---------------- BUZZER ----------------
#define BUZZER 5

// ---------------- KEYPAD ----------------
int rows[4] = {29, 28, 27, 26};
int cols[4] = {25, 24, 23, 22};

char keys[4][4] = {
  {'1','2','3','A'},
  {'4','5','6','B'},
  {'7','8','9','C'},
  {'*','0','#','D'}
};

// ---------------- GAME ----------------
int roundNum = 0;
int qIndex = 0;
int correct = 0;
bool running = false;

// ---------------- QUESTIONS ----------------

// 🧮 MATH (single line)
String mathQ1[5] = {"2+3=?","5+4=?","7+2=?","9+1=?","6+3=?"};
int mathA1[5] = {5,9,9,10,9};

String mathQ2[5] = {"3*3=?","10-4=?","6*2=?","12/3=?","5*4=?"};
int mathA2[5] = {9,6,12,4,20};

String mathQ3[5] = {"15-7=?","8*3=?","20/4=?","9*5=?","18-9=?"};
int mathA3[5] = {8,24,5,45,9};

// 🔬 SCIENCE (line1 question, line2 options)
String sciQ1[5] = {
  "Sun gives light",
  "Earth is our home",
  "Plants make food",
  "We breathe oxygen",
  "Moon moves Earth"
};
String sciOpt1[5] = {
  "A:Star B:Planet",
  "A:Star B:Planet",
  "A:Photo B:Heat",
  "A:O2   B:CO2",
  "A:Planet B:Sat"
};
char sciA1[5] = {'A','B','A','A','B'};

String sciQ2[5] = {
  "Water freezes 0C",
  "Sun rises from",
  "Plants need sun",
  "Earth rotates",
  "Air has oxygen"
};
String sciOpt2[5] = {
  "A:Solid B:Gas",
  "A:East  B:West",
  "A:Food  B:Sleep",
  "A:Day   B:Still",
  "A:Breath B:Light"
};
char sciA2[5] = {'A','A','A','A','A'};

String sciQ3[5] = {
  "Gravity pulls obj",
  "Boiling water is",
  "Plants release O2",
  "Earth moves around",
  "Energy from sun"
};
String sciOpt3[5] = {
  "A:Grav  B:Light",
  "A:Gas   B:Solid",
  "A:Day   B:Night",
  "A:Sun   B:Moon",
  "A:Solar B:Wind"
};
char sciA3[5] = {'A','A','A','A','A'};

// 📘 ENGLISH (line1 question, line2 options)
String engQ1[5] = {
  "Hot opposite?",
  "Big opposite?",
  "Fast same?",
  "Happy opposite?",
  "Up opposite?"
};
String engOpt1[5] = {
  "A:Cold B:Warm",
  "A:Small B:Tall",
  "A:Slow B:Quick",
  "A:Sad  B:Angry",
  "A:Down B:Top"
};
char engA1[5] = {'A','A','B','A','A'};

String engQ2[5] = {
  "Run fast means?",
  "Cold opposite?",
  "Tall opposite?",
  "Cry opposite?",
  "Open opposite?"
};
String engOpt2[5] = {
  "A:Walk B:Sprint",
  "A:Hot  B:Warm",
  "A:Short B:Big",
  "A:Laugh B:Smile",
  "A:Shut B:Wide"
};
char engA2[5] = {'B','A','A','A','A'};

String engQ3[5] = {
  "Brave opposite?",
  "Quick opposite?",
  "Happy same?",
  "Big same?",
  "Start opposite?"
};
String engOpt3[5] = {
  "A:Cow B:Strong",
  "A:Slow B:Rapid",
  "A:Sad B:Glad",
  "A:Huge B:Small",
  "A:End B:Go"
};
char engA3[5] = {'A','A','B','A','A'};

// ---------------- SETUP ----------------
void setup() {
  Serial.begin(9600);

  Wire1.setSDA(6);
  Wire1.setSCL(7);
  Wire1.begin();

  lcd.init();
  lcd.backlight();

  pinMode(START_LED, OUTPUT);
  pinMode(TIMER_LED, OUTPUT);
  pinMode(RESULT_LED, OUTPUT);
  pinMode(BUZZER, OUTPUT);

  for(int i=0;i<4;i++){
    pinMode(rows[i], OUTPUT);
    digitalWrite(rows[i], HIGH);
  }

  for(int i=0;i<4;i++){
    pinMode(cols[i], INPUT_PULLUP);
  }

  // 🎉 Welcome screen
  lcd.setCursor(0,0);
  lcd.print("Welcome to");
  lcd.setCursor(0,1);
  lcd.print("DefuseX");
  delay(3000);

  lcd.clear();
  lcd.print("Press A Start");
}

// ---------------- KEYPAD ----------------
char getKey() {
  for(int i=0;i<4;i++){
    digitalWrite(rows[i], LOW);
    for(int j=0;j<4;j++){
      if(digitalRead(cols[j]) == LOW){
        delay(150);
        while(digitalRead(cols[j]) == LOW);
        digitalWrite(rows[i], HIGH);
        return keys[i][j];
      }
    }
    digitalWrite(rows[i], HIGH);
  }
  return 0;
}

// ---------------- LOOP ----------------
void loop() {

  char k = getKey();

  if(running){
    digitalWrite(TIMER_LED, HIGH);
    delay(100);
    digitalWrite(TIMER_LED, LOW);
  }

  if(k){
    if(k == 'A' && !running) startGame();
    else if(k == 'B' && !running && roundNum < 3){ roundNum++; startRound(); }
    else if(k == 'D') resetGame();
    else if(running) checkAnswer(k);
  }
}

// ---------------- START ----------------
void startGame(){
  roundNum = 1;
  digitalWrite(START_LED, HIGH);
  startRound();
}

// ---------------- ROUND ----------------
void startRound(){
  qIndex = 0;
  correct = 0;
  running = true;
  digitalWrite(RESULT_LED, LOW);

  lcd.clear();
  lcd.print("Round ");
  lcd.print(roundNum);
  delay(1000);

  askQuestion();
}

// ---------------- ASK ----------------
void askQuestion(){
  lcd.clear();
  int sec = qIndex / 5;

  if(sec == 0){ // math
    if(roundNum==1) lcd.print(mathQ1[qIndex%5]);
    else if(roundNum==2) lcd.print(mathQ2[qIndex%5]);
    else lcd.print(mathQ3[qIndex%5]);
  }
  else if(sec == 1){ // science
    lcd.setCursor(0,0);
    if(roundNum==1) lcd.print(sciQ1[qIndex%5]);
    else if(roundNum==2) lcd.print(sciQ2[qIndex%5]);
    else lcd.print(sciQ3[qIndex%5]);

    lcd.setCursor(0,1);
    if(roundNum==1) lcd.print(sciOpt1[qIndex%5]);
    else if(roundNum==2) lcd.print(sciOpt2[qIndex%5]);
    else lcd.print(sciOpt3[qIndex%5]);
  }
  else{ // english
    lcd.setCursor(0,0);
    if(roundNum==1) lcd.print(engQ1[qIndex%5]);
    else if(roundNum==2) lcd.print(engQ2[qIndex%5]);
    else lcd.print(engQ3[qIndex%5]);

    lcd.setCursor(0,1);
    if(roundNum==1) lcd.print(engOpt1[qIndex%5]);
    else if(roundNum==2) lcd.print(engOpt2[qIndex%5]);
    else lcd.print(engOpt3[qIndex%5]);
  }
}

// ---------------- CHECK ----------------
void checkAnswer(char k){

  int sec = qIndex / 5;
  bool ok = false;

  if(roundNum==1){
    if(sec==0 && (k-'0')==mathA1[qIndex%5]) ok=true;
    else if(sec==1 && k==sciA1[qIndex%5]) ok=true;
    else if(sec==2 && k==engA1[qIndex%5]) ok=true;
  }
  else if(roundNum==2){
    if(sec==0 && (k-'0')==mathA2[qIndex%5]) ok=true;
    else if(sec==1 && k==sciA2[qIndex%5]) ok=true;
    else if(sec==2 && k==engA2[qIndex%5]) ok=true;
  }
  else{
    if(sec==0 && (k-'0')==mathA3[qIndex%5]) ok=true;
    else if(sec==1 && k==sciA3[qIndex%5]) ok=true;
    else if(sec==2 && k==engA3[qIndex%5]) ok=true;
  }

  lcd.clear();

  if(ok){
    lcd.print("Correct");
    correct++;
  } else {
    lcd.print("Wrong");
  }

  delay(800);

  qIndex++;

  if(qIndex>=15) endRound();
  else askQuestion();
}

// ---------------- END ----------------
void endRound(){

  lcd.clear();
  lcd.print("Score:");
  lcd.print(correct);
  delay(1500);

  lcd.clear();

  if(correct>=10){
    lcd.print("DEFUSED!");
    digitalWrite(RESULT_LED, HIGH);
  } else {
    lcd.print("BOOM!");
    digitalWrite(BUZZER, HIGH);
    delay(2000);
    digitalWrite(BUZZER, LOW);
  }

  running = false;
}

// ---------------- RESET ----------------
void resetGame(){
  running=false;
  roundNum=0;

  digitalWrite(START_LED, LOW);
  digitalWrite(RESULT_LED, LOW);

  lcd.clear();
  lcd.print("Game Reset");
  delay(1000);

  lcd.clear();
  lcd.print("Press A Start");
}
